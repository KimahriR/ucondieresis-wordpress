# Ejemplo de Variables de Entorno
# Copia este archivo a .env y completa con tus valores

# === DATABASE ===
MYSQL_ROOT_PASSWORD=root_password_segura
MYSQL_DATABASE=ucondieresis_local
MYSQL_USER=wp_user
MYSQL_PASSWORD=wp_password_segura

# === WORDPRESS ===
WORDPRESS_DB_HOST=db
WORDPRESS_DB_NAME=ucondieresis_local
WORDPRESS_DB_USER=wp_user
WORDPRESS_DB_PASSWORD=wp_password_segura
WORDPRESS_TABLE_PREFIX=wp_

# === DESARROLLO ===
WP_ENV=local
WP_DEBUG=true
WP_DEBUG_LOG=/var/www/html/wp-content/debug.log
WP_DEBUG_DISPLAY=false

# === SITIO ===
SITE_URL=http://localhost:8000
HOME_URL=http://localhost:8000
